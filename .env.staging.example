# Staging environment variables — copy to .env.staging on the VM and fill in real values.
# The actual .env.staging file is gitignored and lives only on the VM.
#
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">

POSTGRES_USER=staging
POSTGRES_PASSWORD=<random password>
POSTGRES_DB=writeorperish_staging

FRONTEND_URL=https://staging.loore.org
REACT_APP_BACKEND_URL=https://staging.loore.org
REACT_APP_API_URL=https://staging.loore.org/api

ANTHROPIC_API_KEY_CHAT=<for AI LLM chat responses>
ANTHROPIC_API_KEY_TRAIN=<for training-consented content>
OPENAI_API_KEY_CHAT=<for transcription, TTS, and AI LLM chat>
OPENAI_API_KEY_TRAIN=<for training-consented content>

TWITTER_API_KEY=<same as prod>
TWITTER_API_SECRET=<same as prod>

LLM_NAME=claude-sonnet-4.6

# --- Profile batch processing (issue #173, Part A) ---
# Canary: comma-separated user IDs routed through the Batch API (e.g. 1).
PROFILE_BATCH_USER_IDS=
# Global switch: true sends ALL eligible users via Batch. Both off = the
# synchronous path (no behavior change).
PROFILE_USE_BATCH=false
# Optional separate OpenAI key/quota for batch jobs (falls back to chat key).
OPENAI_API_KEY_BATCH=
# Kill-switch: pause all background profile/recent-context generation (sync
# check, batch seeder, recent-context check) while leaving the batch poller
# running. Use to hand-seed and canary one user in isolation. Default off.
PROFILE_UPDATES_PAUSED=false

# --- Agentic semantic search (issue #155) ---
# Manual Cmd+K semantic search is always on. This flag exposes semantic_search
# as a within-turn LLM tool (+ the {quote:ID} pull-in-full). Ships dark in prod
# (unset/false); on in staging so the agentic flow can be evaluated.
SEMANTIC_SEARCH_AGENTIC=true

MAIL_SERVER=<mail server>
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=<email address>
MAIL_PASSWORD=<password>
MAIL_DEFAULT_SENDER=<email address>
